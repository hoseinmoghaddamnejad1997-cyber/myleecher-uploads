					$(sfpp45a).on("click",function(e) {
						if (e.originalEvent === undefined || c>=pl) {
							$(".download-btn").removeClass("player");
							return;
						}

						$("body").append(pops[c]);

						if (c==1 || c>=pl) {
							$(".download-btn").removeClass("player");
